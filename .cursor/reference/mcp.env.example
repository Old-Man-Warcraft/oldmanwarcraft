# Secrets for MCP (Cursor does NOT reliably expand ${env:VAR} when launched from the GUI).
#
# 1. Copy to:  ~/.cursor/mcp.secrets.env
# 2. Use KEY=value lines (with or without "export "). Quote values if they contain spaces.
# 3. chmod 600 ~/.cursor/mcp.secrets.env
#
# Tokens used by the WRAPPER (sourced before npx/uvx — never put these in mcp.json):
GITLAB_PERSONAL_ACCESS_TOKEN=
FIRECRAWL_API_KEY=
#
# Optional (only if you add github-mcp-server to mcp.base.json):
# GITHUB_PERSONAL_ACCESS_TOKEN=
#
# OMW remote MCP: Cursor does not substitute env in HTTP headers reliably; the regen script
# copies this into ~/.cursor/mcp.json (chmod 600). Rotate this key if it was ever exposed.
OLDMANWARCRAFT_MCP_API_KEY=
#
# After editing secrets, regenerate mcp.json from the repo template:
#   python3 /path/to/azerothcore-wotlk/.cursor/scripts/regenerate_mcp_json.py
#
# The wrapper script must exist and be executable:
#   ~/.cursor/mcp-exec-with-secrets.sh
